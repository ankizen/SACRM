<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting config for the ASP.NET Core Module V2 (in-process hosting).
  `dotnet publish` regenerates a file like this in the publish output automatically;
  this copy is committed so the production hosting settings are reviewable and don't
  depend on remembering to configure them correctly on the server by hand.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\SACRM.WebApi.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
      <!-- Uploaded attachments live in App_Data/uploads (LocalFileStorageService), which IIS
           doesn't serve as static content by default, so no extra lockdown rule is needed here. -->
    </system.webServer>
  </location>
</configuration>
