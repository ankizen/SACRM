# Copy this to .env (untracked -- already covered by .gitignore's `.env` rule) and
# fill in real values before running `docker compose up`, or set these same keys
# directly as environment variables in the Coolify UI for a live deploy.

# SQL Server container's `sa` password -- must satisfy SQL Server's complexity rules
# (8+ chars, upper+lower+digit+symbol).
MSSQL_SA_PASSWORD=Change_This_Password123!

# JWT signing key -- 32+ random characters. Generate a real one, don't reuse this.
JWT_KEY=replace-with-a-long-random-secret-at-least-32-characters

# Bootstraps the first login-capable account on first start (see docs/DOCKER.md).
SEED_MASTER_ADMIN_EMAIL=admin@swarnapp.com
SEED_MASTER_ADMIN_PASSWORD=Change_This_Too123!

# The Vercel URL the frontend is actually deployed at -- CORS rejects everything else.
FRONTEND_URL=https://crm.swarnapp.com
